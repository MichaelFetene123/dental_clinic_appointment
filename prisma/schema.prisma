generator client {
  provider = "prisma-client-js"
  output   = "../src/app/generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ENUMS
// ==========================================



enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BloodType {
  A_PLUS
  A_MINUS
  B_PLUS
  B_MINUS
  O_PLUS
  O_MINUS
  AB_PLUS
  AB_MINUS
  UNKNOWN
}

enum GumCondition {
  HEALTHY
  GINGIVITIS
  PERIODONTITIS
}

enum AppointmentStatus {
  PENDING    // In Queue
  CONFIRMED  // Accepted
  COMPLETED  // Archive
  CANCELLED  // Archive
}

enum TreatmentStatus {
  SCHEDULED
  ONGOING
  COMPLETED
}

enum PaymentStatus {
  PENDING
  PAID
}

// ==========================================
// MODELS
// ==========================================

model User {
  id           String  @id @default(cuid())
  email        String  @unique
  password     String  // Hashed password
  name         String
  phone        String?
  avatar       String? // Local file path under /public/avatars
  avatarFileId String? // Legacy ImageKit fileId kept for cleanup during transition
  isSuperAdmin Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  patient         Patient?       // Optional link to a Patient (for portal access)
  employeeProfile EmployeeProfile?

  // Appointments where this user is the doctor
  doctorAppointments Appointment[] @relation("DoctorAppointments")

  // Auth & RBAC Relations
  userRoles UserRole[]
  sessions  Session[]
  auditLogs AuditLog[]
}

model EmployeeProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  position   String // e.g., "Dentist", "Manager"
  department String // e.g., "Orthodontics", "General"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Patient is now an independent root entity ────────────────────────────────
// A patient does NOT need a User account to exist.
// userId is optional — only set if the patient has been granted portal access.
model Patient {
  id     String  @id @default(cuid())
  userId String? @unique
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Core contact info stored directly on the Patient
  name  String
  email String?
  phone String?

  // Basic Info
  address     String?
  gender      Gender?
  dateOfBirth DateTime?

  // Emergency & Insurance
  emergencyContactName  String?
  emergencyContactPhone String?
  insuranceProvider     String?
  insuranceNumber       String?

  // Vitals & General Health
  bloodType       BloodType @default(UNKNOWN)
  height          String?
  weight          String?
  bloodPressure   String?
  heartRate       String?
  bloodSugarLevel String?
  allergies       String?
  medications     String?
  chronicDiseases String?
  medicalHistory  String?

  // Dental Specific
  lastDentalVisit   DateTime?
  gumCondition      GumCondition @default(HEALTHY)
  toothDecay        String?
  missingTeethCount String?
  prostheticsUsed   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  appointments     Appointment[]
  dentalHistory    DentalHistory[]
  medicalDocuments MedicalDocument[]

  @@map("PatientProfile")
}

model Appointment {
  id String @id @default(cuid())

  // Every appointment MUST belong to a Patient
  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  // Assigned Doctor
  doctorId String?
  doctor   User?   @relation("DoctorAppointments", fields: [doctorId], references: [id])

  // Appointment Details
  date   DateTime
  time   String // e.g., "14:30"
  reason String
  notes  String?
  status AppointmentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  dentalHistory DentalHistory?
}

model DentalHistory {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  appointmentId String?      @unique
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  treatmentType   String
  treatmentStatus TreatmentStatus @default(SCHEDULED)
  paymentStatus   PaymentStatus   @default(PENDING)
  date            DateTime        @default(now())
  notes           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MedicalDocument {
  id String @id @default(cuid())

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  name      String  // e.g., "X-Ray_Report.pdf"
  fileUrl   String  // S3 URL or local path
  sizeBytes Int     // File size in bytes for dynamic conversion (e.g., "2.3mb")
  type      String  // MIME type

  uploadedAt DateTime @default(now())
}

// ==========================================
// RBAC MODELS
// ==========================================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id // e.g., "patient.read"
  resource    String   // e.g., "patient"
  action      String   // e.g., "read"
  description String?  // e.g., "Can view patient basic info"
  createdAt   DateTime @default(now())

  roles       RolePermission[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

// ==========================================
// AUTH MODELS
// ==========================================

model Session {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyId            String   // Groups refresh token rotations together
  tokenHash           String   @unique // Active session token hash
  refreshHash         String   @unique // Active refresh token hash
  previousRefreshHash String?          // For reuse detection
  tokenExpiresAt      DateTime         // 15 min sliding
  refreshExpiresAt    DateTime         // 7 days absolute
  rotationCount       Int      @default(0)
  revokedAt           DateTime?
  permissionsJson     String   @default("[]") // Cached flat array of permission IDs
  ipAddress           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([userId])
  @@index([familyId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // e.g., "CREATE", "UPDATE", "DELETE", "LOGIN"
  resource   String   // e.g., "Patient", "Appointment", "Session"
  resourceId String?  // ID of the affected resource
  details    String?  // JSON string with more details
  ipAddress  String?
  timestamp  DateTime @default(now())
}
